@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center mt-5">
    <h1 class="text-danger"><i class="bi bi-exclamation-triangle"></i> Error</h1>
    <h2 class="text-danger">Ocurrió un error al procesar su solicitud.</h2>

    <p class="mt-4">Por favor, intente nuevamente más tarde. Si el problema persiste, contacte al administrador del sistema.</p>

    <a asp-page="/Alumnos/Index" class="btn btn-primary mt-3">
        <i class="bi bi-arrow-left"></i> Volver a la lista de alumnos
    </a>
</div>
