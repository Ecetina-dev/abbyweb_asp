@page
@model AbbyWeb.Pages.Alumnos.CreateModel

<form method="post">
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary pl-3">Crear Alumno</h2>
            <hr />
        </div>
        <div asp-validation-summary="All"></div>
        <div class="row">
            <div class="col-6">
                <div class="mb-3">
                    <label asp-for="Alumno.no_control"></label>
                    <input asp-for="Alumno.no_control" class="form-control" />
                    <span asp-validation-for="Alumno.no_control" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Alumno.nombre"></label>
                    <input asp-for="Alumno.nombre" class="form-control" />
                    <span asp-validation-for="Alumno.nombre" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Alumno.apellido_paterno"></label>
                    <input asp-for="Alumno.apellido_paterno" class="form-control" />
                    <span asp-validation-for="Alumno.apellido_paterno" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Alumno.apellido_materno"></label>
                    <input asp-for="Alumno.apellido_materno" class="form-control" />
                    <span asp-validation-for="Alumno.apellido_materno" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Alumno.email"></label>
                    <input asp-for="Alumno.email" class="form-control" />
                    <span asp-validation-for="Alumno.email" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Alumno.telefono"></label>
                    <input asp-for="Alumno.telefono" class="form-control" />
                    <span asp-validation-for="Alumno.telefono" class="text-danger"></span>
                </div>
            </div>
            <div class="col-6">
                <div class="mb-3">
                    <label asp-for="Alumno.genero"></label>
                    <select asp-for="Alumno.genero" class="form-control">
                        <option value="">-- Seleccione --</option>
                        <option value="Masculino">Masculino</option>
                        <option value="Femenino">Femenino</option>
                        <option value="Otro">Otro</option>
                    </select>
                    <span asp-validation-for="Alumno.genero" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Alumno.fecha_nacimiento"></label>
                    <input asp-for="Alumno.fecha_nacimiento" class="form-control" type="date" />
                    <span asp-validation-for="Alumno.fecha_nacimiento" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Alumno.id_carrera"></label>
                    <select asp-for="Alumno.id_carrera" asp-items="Model.Carreras" class="form-control">
                        <option value="">-- Seleccione --</option>
                    </select>
                    <span asp-validation-for="Alumno.id_carrera" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Alumno.semestre"></label>
                    <input asp-for="Alumno.semestre" class="form-control" type="number" min="1" max="12" />
                    <span asp-validation-for="Alumno.semestre" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Alumno.grupo"></label>
                    <input asp-for="Alumno.grupo" class="form-control" />
                    <span asp-validation-for="Alumno.grupo" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Alumno.turno"></label>
                    <select asp-for="Alumno.turno" class="form-control">
                        <option value="">-- Seleccione --</option>
                        <option value="Matutino">Matutino</option>
                        <option value="Vespertino">Vespertino</option>
                    </select>
                    <span asp-validation-for="Alumno.turno" class="text-danger"></span>
                </div>
            </div>
        </div>
        <button type="submit" class="btn btn-primary" style="width:150px;">Crear</button>
        <a asp-page="Index" class="btn btn-secondary" style="width:150px;">Volver a Lista</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
