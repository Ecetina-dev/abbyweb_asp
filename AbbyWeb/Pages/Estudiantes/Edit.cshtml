@page
@model AbbyWeb.Pages.Estudiantes.EditModel
@{
    ViewData["Title"] = "Editar Estudiante";
}

<h1>Editar Estudiante</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="Estudiante.Id_Estudiante" />

            <div class="form-group mb-3">
                <label asp-for="Estudiante.Nombres" class="control-label"></label>
                <input asp-for="Estudiante.Nombres" class="form-control" />
                <span asp-validation-for="Estudiante.Nombres" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Estudiante.Apellidos" class="control-label"></label>
                <input asp-for="Estudiante.Apellidos" class="form-control" />
                <span asp-validation-for="Estudiante.Apellidos" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Estudiante.Direccion" class="control-label"></label>
                <input asp-for="Estudiante.Direccion" class="form-control" />
                <span asp-validation-for="Estudiante.Direccion" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Estudiante.Universidad" class="control-label"></label>
                <input asp-for="Estudiante.Universidad" class="form-control" />
                <span asp-validation-for="Estudiante.Universidad" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Estudiante.Telefono" class="control-label"></label>
                <input asp-for="Estudiante.Telefono" class="form-control" />
                <span asp-validation-for="Estudiante.Telefono" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Estudiante.Correo" class="control-label"></label>
                <input asp-for="Estudiante.Correo" class="form-control" />
                <span asp-validation-for="Estudiante.Correo" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Estudiante.Semestre" class="control-label"></label>
                <input asp-for="Estudiante.Semestre" class="form-control" />
                <span asp-validation-for="Estudiante.Semestre" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <input type="submit" value="Actualizar" class="btn btn-primary" />
                <a asp-page="Index" class="btn btn-secondary">Volver a Lista</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
